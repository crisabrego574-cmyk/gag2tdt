local function isPlotFull()
    local plotId = LP:GetAttribute("PlotId")
    if not plotId then return false end
    local plot = Workspace.Gardens:FindFirstChild("Plot" .. tostring(plotId))
    if plot then
        return countPlantsInPlot(plot) >= (Settings.MaxPlantsBeforeShovel or 200)
    end
    return false
end

local function isSprinklerNeeded()
    if not Settings.AutoSprinkler or not hasSprinklerTool() then return false end
    local plotId = LP:GetAttribute("PlotId")
    if not plotId then return false end
    local plot = Workspace.Gardens:FindFirstChild("Plot" .. tostring(plotId))
    if not plot then return false end
    local plantsFolder = plot:FindFirstChild("Plants")
    if not plantsFolder then return false end
    local existingCoverage = getExistingSprinklersCoverage(plot)
    for _, plant in ipairs(plantsFolder:GetChildren()) do
        if plant:IsA("Model") then
            local seedName = plant:GetAttribute("SeedName")
            if seedName then
                local rarity = rarityMap[seedName] or "Common"
                if isRarityAtLeast(rarity, Settings.AutoSprinklerMinRarity or "Legendary") then
                    local plantPos = plant:GetPivot().Position
                    if not isPositionCovered(plantPos, existingCoverage) then
                        return true
                    end
                end
            end
        end
    end
    return false
end

local function getStatusText()
    if env.IsPaused then return "Stop when event weather start" end
    if not env.Initialized then return "Moving to Garden..." end
    if env.SavingForPet and env.SavingForPetPrice then
        local cur = getSheckles()
        local need = env.SavingForPetPrice
        local petName = env.SavingForPetName or "Pet"
        return "Farming Sheckles Buy Pet ("..petName..") "..formatMoney(cur).."/"..formatMoney(need)
    end
    if Settings.AutoHarvest then return "Collect Fruits" end
    local bestTool = findMatchingSeedTool()
    if Settings.AutoPlant and bestTool and findEmptyPlantPosition() then return "Planting Seeds" end
    if Settings.AutoShovel and hasShovelTool() and isPlotFull() then return "Shovel Tree" end
    if isSprinklerNeeded() then return "Use Sprinkler" end
    if Settings.AutoCollectSeedPack then return "Collect Seed" end
    if Settings.AutoBuyPets then return "Buying Pet" end

    return "Idle"
end

