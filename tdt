local function findMatchingSeedTool()
    if not Settings.PlantAllSeed then return nil, false end
    for _, entry in ipairs(getAllSeedTools()) do
        local cleanName = entry.tool.Name:gsub(" Seed", ""):gsub(" seed", "")
        if cleanName == "Rainbow" and not Settings.SeedPlant_Rainbow then
        elseif cleanName == "Gold" and not Settings.SeedPlant_Gold then
        else
            return entry.tool, entry.equipped
        end
    end
