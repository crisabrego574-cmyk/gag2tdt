local RARITY_RANK = { Common = 1, Uncommon = 2, Rare = 3, Epic = 4, Super = 5, Legendary = 6, Mythic = 7 }
local function isRarityAtLeast(plantRarity, minRarity)
    return (RARITY_RANK[plantRarity] or 0) >= (RARITY_RANK[minRarity] or 0)
end

local function formatMoney(n)
    if n >= 1e6 then
        local v = n / 1e6
        return (v == math.floor(v)) and (math.floor(v).."M") or string.format("%.1fM", v)
    elseif n >= 1e3 then
        local v = n / 1e3
        return (v == math.floor(v)) and (math.floor(v).."K") or string.format("%.1fK", v)
    else
        return tostring(n)
    end
end

