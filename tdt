        return replica.Data and replica.Data.Inventory
    end

    local function countEquippedPets(inventory)
        if not inventory or not inventory.Pets then return 0 end
        local count = 0
        for _, petData in pairs(inventory.Pets) do
            if type(petData) == "table" and petData.Equipped == true then
                count = count + 1
            end
        end
        return count
    end

    local function getMaxPetSlots()
        local attr = LP:GetAttribute("PetSlots") or LP:GetAttribute("MaxPets") or LP:GetAttribute("PetSlotCount")
        if attr then return attr end
        local ls = LP:FindFirstChild("leaderstats")
        if ls then
            local slots = ls:FindFirstChild("PetSlots") or ls:FindFirstChild("MaxPets")
            if slots then return slots.Value end
        end
        return 3
    end

    local function equipPet(itemKey)
        local equipped = false
        pcall(function()
            if Networking.Pets and Networking.Pets.EquipPet then
                Networking.Pets.EquipPet:Fire(itemKey)
                equipped = true
            elseif Networking.Pet and Networking.Pet.Equip then
                Networking.Pet.Equip:Fire(itemKey)
                equipped = true
            elseif Networking.Actions and Networking.Actions.EquipPet then
                Networking.Actions.EquipPet:Fire(itemKey)
                equipped = true
            else
                local remote = RS:FindFirstChild("EquipPet", true)
                if remote and remote:IsA("RemoteEvent") then
                    remote:FireServer(itemKey)
                    equipped = true
                end
            end
        end)
        return equipped
    end

    while true do
        if env.Initialized and not env.IsPaused then
            if Settings.Enabled then
                local inventory = getInventoryData()
                if inventory and inventory.Pets then
                    local maxSlots = getMaxPetSlots()
                    local equippedCount = countEquippedPets(inventory)

                    if equippedCount >= maxSlots then
                    else
                        local slotsAvailable = maxSlots - equippedCount
                        local equipped = 0
                        for itemKey, petData in pairs(inventory.Pets) do
                            if equipped >= slotsAvailable then break end
                            if type(petData) == "table" and petData.Equipped ~= true then
                                local ok = equipPet(itemKey)
                                if ok then
                                    equipped = equipped + 1
                                    wait(0.5) 
                                end
                            end
                        end
                    end
                end
            end
        end
        wait(5)
    end
end)

