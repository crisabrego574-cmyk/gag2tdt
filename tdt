spawn(function()
    if not Settings.Gift or not Settings.Gift.Enabled then return end
    local PlayerStateClient = require(RS.ClientModules.PlayerStateClient)
    local function isMatch(itemName, configList)
        if not itemName or not configList then return false end
        for _, name in ipairs(configList) do
            local configName = string.lower(tostring(name))
            if configName == "all" then return true end
            if string.lower(tostring(itemName)) == configName then return true end
        end
        return false
    end
    local function autoSendFilteredItems()
        local targetUserId = nil
        pcall(function()
            local res = Networking.Mailbox.LookupPlayer:Fire(Settings.Gift.Account)
            if type(res) == "number" and res > 0 then targetUserId = res end
        end)
        if not targetUserId then return end
        local replica = PlayerStateClient:GetLocalReplica()
        if not replica or not replica.Data or not replica.Data.Inventory then return end
        local inventory = replica.Data.Inventory
        local itemsToSend = {}
        if inventory.Pets then
            for itemKey, data in pairs(inventory.Pets) do
                if type(data) == "table" and data.Id and not data.Equipped then
                    if isMatch(data.Id, Settings.Gift.Pet) or isMatch(itemKey, Settings.Gift.Pet) then
                        table.insert(itemsToSend, {Category = "Pets", ItemKey = itemKey, Count = 1})
                    end
                end
            end
        end
        if inventory.Seeds then
            for itemKey, amount in pairs(inventory.Seeds) do
                if type(amount) == "number" and amount > 0 then
                    if isMatch(itemKey, Settings.Gift.Seed) then
                        table.insert(itemsToSend, {Category = "Seeds", ItemKey = itemKey, Count = amount})
                    end
                end
            end
        end
        local gearCategories = {"Sprinklers", "WateringCans", "Mushrooms", "Gnomes", "Trowels", "Props"}
        for _, category in ipairs(gearCategories) do
            if inventory[category] then
                for itemKey, amount in pairs(inventory[category]) do
                    if type(amount) == "number" and amount > 0 then
                        if isMatch(itemKey, Settings.Gift.Gear) then
                            table.insert(itemsToSend, {Category = category, ItemKey = itemKey, Count = amount})
                        end
                    end
                end
            end
        end
        if #itemsToSend == 0 then return end
        local noteMessage = "Gifted by Auto Script"
        for startIdx = 1, #itemsToSend, 20 do
            local batch = {}
            for idx = startIdx, math.min(startIdx + 19, #itemsToSend) do
                table.insert(batch, itemsToSend[idx])
            end
            pcall(function()
                Networking.Mailbox.SendBatch:Fire(targetUserId, batch, noteMessage)
            end)
            wait(0.5)
        end
    end
    while true do
        if env.Initialized and not env.IsPaused then
            if Settings.Gift.Enabled then
                autoSendFilteredItems()
            end
        end
        wait(3)
    end
end)

