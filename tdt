local function countPlantsInPlot(plot)
    local plantsFolder = plot and plot:FindFirstChild("Plants")
    if not plantsFolder then return 0 end
    local count = 0
    for _, plant in ipairs(plantsFolder:GetChildren()) do
        if plant:IsA("Model") then count = count + 1 end
    end
    return count
end

local function findSprinklerTool(targetName)
    local candidates = {}
    local backpack = LP:FindFirstChild("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") and tool:GetAttribute("Sprinkler") then
                table.insert(candidates, tool)
            end
        end
    end
    local char = LP.Character
    if char then
        local equipped = char:FindFirstChildWhichIsA("Tool")
        if equipped and equipped:GetAttribute("Sprinkler") then
            table.insert(candidates, equipped)
        end
    end
    if #candidates == 0 then return nil end
    if targetName == "Best" then
        table.sort(candidates, function(a, b)
            local dataA = sprinklerDataMap[a:GetAttribute("Sprinkler")]
            local dataB = sprinklerDataMap[b:GetAttribute("Sprinkler")]
            local radiusA = dataA and dataA.Radius or 0
            local radiusB = dataB and dataB.Radius or 0
            return radiusA > radiusB
        end)
        return candidates[1]
    else
        for _, tool in ipairs(candidates) do
            if tool:GetAttribute("Sprinkler") == targetName then return tool end
        end
    end
    return nil
end

local function getExistingSprinklersCoverage(plot)
    local coverageList = {}
    if not plot then return coverageList end
    local sprinklersFolder = plot:FindFirstChild("Sprinklers")
    if sprinklersFolder then
        for _, sprinkler in ipairs(sprinklersFolder:GetChildren()) do
            if sprinkler:IsA("Model") and sprinkler.PrimaryPart then
                local pos = sprinkler.PrimaryPart.Position
                local name = sprinkler.Name
                local data = sprinklerDataMap[name]
                local radius = data and data.Radius or 20
                table.insert(coverageList, {position = pos, radius = radius})
            end
        end
    end
    return coverageList
end

local function isPositionCovered(position, coverageList)
    for _, cov in ipairs(coverageList) do
        local distXZ = (Vector3.new(position.X, 0, position.Z) - Vector3.new(cov.position.X, 0, cov.position.Z)).Magnitude
        if distXZ <= cov.radius then return true end
    end
    return false
end

env.getSeedLocations = function()
    local seeds = {}
    local map = Workspace:FindFirstChild("Map")
    if map then
        for _, folderName in ipairs({"SeedPackSpawnClient", "SeedPackSpawnServerLocations"}) do
            local folder = map:FindFirstChild(folderName)
            if folder then
                for _, part in ipairs(folder:GetChildren()) do
                    if part:IsA("BasePart") or part:IsA("Model") then
                        local prompt = part:FindFirstChildWhichIsA("ProximityPrompt", true)
                        if prompt and prompt.Enabled then
                            local targetPart = part:IsA("Model") and part.PrimaryPart or part
                            if targetPart then
                                table.insert(seeds, {model=part, pos=targetPart.Position + Vector3.new(0, targetPart.Size.Y/2 + 3, 0)})
                            end
                        end
                    end
                end
            end
        end
    end
    if #seeds == 0 then
        for _, tag in ipairs({"SeedPrompt","CollectSeed","SeedPackPrompt"}) do
            for _, prompt in ipairs(CollectionService:GetTagged(tag)) do
                if prompt:IsA("ProximityPrompt") and prompt.Enabled and prompt.Parent:IsA("BasePart") then
                    table.insert(seeds, {model=prompt.Parent, pos=prompt.Parent.Position + Vector3.new(0, prompt.Parent.Size.Y/2 + 3, 0)})
                end
            end
        end
    end
    return seeds
end

env.tpAndFireSeedPrompt = function(seed)
    safeTeleport(seed.pos)
    wait(0.15)

    local prompt = seed.model:FindFirstChildWhichIsA("ProximityPrompt", true)
    if not prompt then return end

    local old = prompt.MaxActivationDistance
    prompt.MaxActivationDistance = math.huge
    if fireproximityprompt then
        fireproximityprompt(prompt, 0)
    else
        prompt:InputHoldBegin()
        wait(0.05)
        prompt:InputHoldEnd()
    end
    prompt.MaxActivationDistance = old
end

