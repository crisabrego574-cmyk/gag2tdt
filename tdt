                                for _, plant in ipairs(plantsFolder:GetChildren()) do
                                    if not Settings.AutoSprinkler or env.IsPlanting then break end

                                    if plant:IsA("Model") then
                                        local seedName = plant:GetAttribute("SeedName")
                                        if seedName then
                                            local rarity = rarityMap[seedName] or "Common"
                                            if isRarityAtLeast(rarity, Settings.AutoSprinklerMinRarity or "Legendary") then
                                                local plantPos = plant:GetPivot().Position
                                                if not isPositionCovered(plantPos, existingCoverage) then
                                                    local char = LP.Character
                                                    if char and sprinklerTool and sprinklerTool.Parent ~= nil and sprinklerTool.Parent ~= char then
                                                        local humanoid = char:FindFirstChildOfClass("Humanoid")
                                                        if humanoid then
                                                            pcall(function() humanoid:EquipTool(sprinklerTool) end)
                                                            wait(0.5)
                                                        end
                                                    end
                                                    local sprinklerName = sprinklerTool:GetAttribute("Sprinkler")
                                                    pcall(function()
                                                        if Networking and Networking.Place and Networking.Place.PlaceSprinkler then
                                                            Networking.Place.PlaceSprinkler:Fire(plantPos, sprinklerName, sprinklerTool, plotId)
                                                        elseif Networking and Networking.Garden and Networking.Garden.PlaceSprinkler then
                                                            Networking.Garden.PlaceSprinkler:Fire(plantPos, sprinklerName, sprinklerTool, plotId)
                                                        end
                                                        if sprinklerTool and sprinklerTool.Parent == char then
                                                            sprinklerTool:Activate()
                                                        end
                                                    end)
                                                    wait(0.5)
                                                    existingCoverage = getExistingSprinklersCoverage(plot)
                                                end
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
        wait(5)
    end
end)

spawn(function()
    local StarterGui = game:GetService("StarterGui")
    local MAX_PETS = 4

    local function countEquippedByList()
        local character = LocalPlayer.Character
        if not character then return 0 end
        local count = 0
        for _, tool in ipairs(character:GetChildren()) do
            if tool:IsA("Tool") and tool:GetAttribute("Pet") then
                count = count + 1
            end
        end
        return count
    end

    local function autoEquipByList()
        if not Settings.EquipPetsEnabled then return end
        local character = LocalPlayer.Character
        if not character then return end

        local currentCount = countEquippedByList()
        if currentCount >= MAX_PETS then return end

        local sorted = {}
        for _, entry in ipairs(Settings.EquipPetList or {}) do
            if type(entry) == "table" and #entry == 2 then
                table.insert(sorted, {name = entry[1], priority = entry[2]})
            end
        end
        table.sort(sorted, function(a, b) return a.priority < b.priority end)

        local backpack = LocalPlayer:FindFirstChild("Backpack")
        if not backpack then return end

        for _, petData in ipairs(sorted) do
            if currentCount >= MAX_PETS then break end
            local petName = petData.name
            for _, tool in ipairs(backpack:GetChildren()) do
                if currentCount >= MAX_PETS then break end
                if tool:IsA("Tool") and tool:GetAttribute("Pet") == petName then
                    tool.Parent = character
                    currentCount = currentCount + 1
                    task.spawn(function()
                        task.wait(0.5)
                        if tool and tool.Parent and tool:IsDescendantOf(character) then
                            pcall(function() tool:Activate() end)
                        end
                    end)
                    wait(0.2)
                end
            end
        end
    end

    while true do
        if env.Initialized and not env.IsPaused then
            if Settings.EquipPetsEnabled then
                pcall(autoEquipByList)
            end
        end
        wait(3)
    end
end)

