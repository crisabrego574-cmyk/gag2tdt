local _tpToken = 0

local function safeTeleport(targetPos)
    local char = LP.Character
    if not char then return end

    local HRP = char:FindFirstChild("HumanoidRootPart")
    local Humanoid = char:FindFirstChildOfClass("Humanoid")
    if not HRP or not Humanoid or Humanoid.Health <= 0 then return end

    _tpToken = _tpToken + 1
    local myToken = _tpToken

    local safePos = Vector3.new(targetPos.X, targetPos.Y + 3.5, targetPos.Z)
    local targetCFrame = CFrame.new(safePos)

    pcall(function()
        HRP.AssemblyLinearVelocity = Vector3.zero
        HRP.AssemblyAngularVelocity = Vector3.zero
    end)

    HRP.Anchored = true
    char:PivotTo(targetCFrame)

    task.spawn(function()
        local elapsed = 0
        while elapsed < 0.18 do
            if myToken ~= _tpToken then return end
            if HRP then
                if not HRP.Anchored then HRP.Anchored = true end
                HRP.CFrame = targetCFrame
                HRP.AssemblyLinearVelocity = Vector3.zero
                HRP.AssemblyAngularVelocity = Vector3.zero
            end
            elapsed = elapsed + RunService.Heartbeat:Wait()
        end

        if myToken == _tpToken and HRP then
            HRP.AssemblyLinearVelocity = Vector3.zero
            HRP.Anchored = false
        end
    end)
end

local function getHomePosition()
    local plotId = LP:GetAttribute("PlotId")
    local gardens = Workspace:FindFirstChild("Gardens")

    if gardens then
        local plot = nil
        if plotId then
            plot = gardens:FindFirstChild("Plot" .. tostring(plotId))
        end
        if not plot then
            for _, p in ipairs(gardens:GetChildren()) do
                if p:GetAttribute("Owner") == LP.Name or p:GetAttribute("OwnerId") == LP.UserId then
                    plot = p
                    break
                end
            end
        end

        if plot then
            local gardenZone = plot:FindFirstChild("Visual") and plot.Visual:FindFirstChild("GardenZonePart")
            local spawnPoint = plot:FindFirstChild("SpawnPoint")

            if gardenZone and spawnPoint then
                local targetX = gardenZone.Position.X
                local targetY = spawnPoint.Position.Y
                local targetZ = gardenZone.Position.Z
                return Vector3.new(targetX, targetY, targetZ)
            elseif gardenZone then
                return gardenZone.Position
            end

            return plot:GetPivot().Position
        end
    end

    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    return hrp and hrp.Position or Vector3.new(0, 5, 0)
end

local GARDEN_RADIUS = 60
local function isNearHome(position)
    local homePos = getHomePosition()
    local flatHome = Vector3.new(homePos.X, 0, homePos.Z)
    local flatPos = Vector3.new(position.X, 0, position.Z)
    return (flatHome - flatPos).Magnitude < GARDEN_RADIUS
end

local function returnToHomeLoop()
    if env.IsReturning then return end
    env.IsReturning = true

    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        local targetPos = getHomePosition()
        local seeds = env.getSeedLocations()
        if #seeds > 0 then
            for _, seed in ipairs(seeds) do
                env.tpAndFireSeedPrompt(seed)
                wait(0.2)
            end
        else
            safeTeleport(targetPos)
            wait(0.5)
        end
    end

    env.IsReturning = false
end

